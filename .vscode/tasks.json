{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "terraform apply all vault secrets",
            "type": "shell",
            "command": "terraform apply -input=false -auto-approve",
            "options": {
                "cwd": "${workspaceFolder}/vault-secrets/"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
        },
        {
            "label": "terraform format all",
            "type": "shell",
            "command": "./scripts/terraform_fmt_all.sh",
            "options": {
                "cwd": "${workspaceFolder}/"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
        },
    ]
}